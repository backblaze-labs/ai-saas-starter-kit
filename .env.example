# Backblaze B2 — S3-compatible API (the first four below are required)
B2_APPLICATION_KEY_ID=your_key_id
B2_APPLICATION_KEY=your_application_key
B2_BUCKET_NAME=your-bucket-name
B2_REGION=your_region

# Optional — a stable public base URL for objects. Leave UNSET to serve files
# via short-lived presigned URLs (the default; the file manager works fully
# without this). Set it only for a public bucket where you want durable links.
B2_PUBLIC_URL_BASE=your_public_url_base

# Frontend → API base URL (optional). The web app reads this at build time and
# defaults to http://localhost:8000 for local dev. Set it to your deployed API
# origin in production (e.g. https://api-production-xxx.up.railway.app).
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Example of what filled-in values look like (fake — for visual reference only):
# B2_APPLICATION_KEY_ID=00abcdef1234567000000001
# B2_APPLICATION_KEY=<your-application-key-shown-once-on-creation>
# B2_BUCKET_NAME=my-app-uploads
# B2_REGION=us-west-004
# B2_PUBLIC_URL_BASE=https://my-app-uploads.s3.us-west-004.backblazeb2.com
