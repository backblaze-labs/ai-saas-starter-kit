# Backblaze B2 — S3-compatible API (the first four below are required)
B2_APPLICATION_KEY_ID=your_key_id
B2_APPLICATION_KEY=your_application_key
B2_BUCKET_NAME=your-bucket-name
B2_REGION=your_region

# Optional — a stable public base URL for objects. Leave UNSET to serve files
# via short-lived presigned URLs (the default; the file manager works fully
# without this). Set it only for a public bucket where you want durable links.
B2_PUBLIC_URL_BASE=your_public_url_base

# --- Supabase (auth + Postgres) — required ---
# LOCAL: run `supabase start`, then `node scripts/sync-supabase-env.mjs` to fill
# these five from your local stack. HOSTED: copy the values from your project's
# Project Settings -> API. Swapping local <-> hosted is config-only.
# Frontend (browser-exposed):
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Backend (server-only; never expose the service-role key to the browser):
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your_supabase_anon_key
# Required for the billing webhook (it writes subscription rows bypassing RLS)
# and for plan-gating reads. Local `supabase start` prints this; hosted projects
# expose it in Project Settings -> API.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Stripe billing (optional to boot) ---
# The auth + file-manager scaffold runs without these; billing endpoints return
# a clean 503 until they are set. Use TEST-mode keys from the Stripe Dashboard.
# Price IDs are account-specific: create a recurring Price per paid plan in your
# Stripe product catalog and paste its id (price_...) below.
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
STRIPE_PRICE_PRO=price_your_pro_price_id
STRIPE_PRICE_TEAM=price_your_team_price_id

# Frontend → API base URL (optional). The web app reads this at build time and
# defaults to http://localhost:8000 for local dev. Set it to your deployed API
# origin in production (e.g. https://api-production-xxx.up.railway.app).
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Example of what filled-in values look like (fake — for visual reference only):
# B2_APPLICATION_KEY_ID=00abcdef1234567000000001
# B2_APPLICATION_KEY=<your-application-key-shown-once-on-creation>
# B2_BUCKET_NAME=my-app-uploads
# B2_REGION=us-west-004
# B2_PUBLIC_URL_BASE=https://my-app-uploads.s3.us-west-004.backblazeb2.com
