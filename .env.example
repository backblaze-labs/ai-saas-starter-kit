# Backblaze B2 — S3-compatible API (the first four below are required)
B2_APPLICATION_KEY_ID=your_key_id
B2_APPLICATION_KEY=your_application_key
B2_BUCKET_NAME=your-bucket-name
B2_REGION=your_region

# Optional — a stable public base URL for objects. Leave UNSET to serve files
# via short-lived presigned URLs (the default; the file manager works fully
# without this). Set it only for a public bucket where you want durable links.
B2_PUBLIC_URL_BASE=your_public_url_base

# --- Supabase (auth + Postgres) — required ---
# LOCAL: run `supabase start`, then `node scripts/sync-supabase-env.mjs` to fill
# these from your local stack. HOSTED: copy the values from your project's
# Project Settings -> API. Swapping local <-> hosted is config-only.
# The URL + anon key live in ONE place: the FastAPI backend reads the same two
# NEXT_PUBLIC_* vars (it falls back to them), so there is nothing to duplicate.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Server-only; never expose the service-role key to the browser. Required at boot
# (billing webhook writes subscription rows + plan-gating reads bypass RLS). Local
# `supabase start` prints this; hosted projects expose it in Project Settings -> API.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Split deploy only (optional): if you run the FastAPI backend somewhere you'd
# rather NOT set NEXT_PUBLIC_* names, set these instead — they override the
# fallback above. Leave them unset for a single .env.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# --- AI media generation: NVIDIA NIM (optional to boot) ---
# Powers the /generate workflow (text-to-image via flux.1-schnell), orchestrated
# by the Genblaze SDK and written to B2. The endpoint returns a clean 503 until
# this is set. Get a free key with starter credits at https://build.nvidia.com
# (the key looks like nvapi-...). Model + image size are configurable in
# services/api/app/config/settings.py (NVIDIA_IMAGE_MODEL, GENERATION_*).
NVIDIA_API_KEY=nvapi-your-nvidia-nim-key

# --- Stripe billing (optional to boot) ---
# The auth + file-manager scaffold runs without these; billing endpoints return
# a clean 503 until they are set. Use TEST-mode keys from the Stripe Dashboard.
# Price IDs are account-specific: create a recurring Price per paid plan in your
# Stripe product catalog and paste its id (price_...) below.
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
STRIPE_PRICE_PRO=price_your_pro_price_id
STRIPE_PRICE_TEAM=price_your_team_price_id

# Frontend → API base URL (optional). The web app reads this at build time and
# defaults to http://localhost:8000 for local dev. Set it to your deployed API
# origin in production (e.g. https://api-production-xxx.up.railway.app).
# NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Production overrides (unset locally; needed once deployed) ---
# CORS allowlist for the API (comma-separated). Defaults to localhost — add your
# deployed frontend origin or the browser gets CORS errors against the live API.
# API_CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
# Stripe redirect targets. Default to localhost:3000 — point them at your deployed
# frontend so post-checkout redirects land on the live app instead of localhost.
# BILLING_SUCCESS_URL=https://your-app.vercel.app/billing?checkout=success
# BILLING_CANCEL_URL=https://your-app.vercel.app/billing?checkout=cancelled
# BILLING_PORTAL_RETURN_URL=https://your-app.vercel.app/billing

# Example of what filled-in values look like (fake — for visual reference only):
# B2_APPLICATION_KEY_ID=00abcdef1234567000000001
# B2_APPLICATION_KEY=<your-application-key-shown-once-on-creation>
# B2_BUCKET_NAME=my-app-uploads
# B2_REGION=us-west-004
# B2_PUBLIC_URL_BASE=https://my-app-uploads.s3.us-west-004.backblazeb2.com
